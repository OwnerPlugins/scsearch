<screen name="SCDetailsScreen" position="center,center" size="2560,1440" title="SC Search - Details" backgroundColor="#101216">
    <widget name="title" position="80,80" size="2400,80" font="Regular;56" foregroundColor="#ffffff" backgroundColor="#101216" transparent="1" />
    <widget name="type_info" position="80,180" size="1200,60" font="Regular;40" foregroundColor="#f0c36a" backgroundColor="#101216" transparent="1" />

    <!-- Larger cover on the left -->
    <widget name="cover_pixmap" position="80,280" size="600,900" zPosition="3" alphatest="on" />

    <!-- Smaller detailed info -->
    <widget name="info_panel" position="720,280" size="560,400" font="Regular;36" foregroundColor="#ffffff" backgroundColor="#1b2028" />

    <!-- Even wider description -->
    <widget name="description_panel" position="1320,280" size="1160,400" font="Regular;32" foregroundColor="#aab2c0" backgroundColor="#151922" />

    <!-- Seasons and episodes below -->
    <widget name="season_label" position="720,720" size="600,60" font="Regular;40" foregroundColor="#ffffff" backgroundColor="#101216" transparent="1" />
    <widget name="season_list" position="720,800" size="600,300" itemHeight="70" backgroundColor="#1b2028" foregroundColor="#ffffff" font="Regular;36" selectionPixmap="skin_default/sel.png" />

    <widget name="episode_label" position="1360,720" size="600,60" font="Regular;40" foregroundColor="#ffffff" backgroundColor="#101216" transparent="1" />
    <widget name="episode_list" position="1360,800" size="600,300" itemHeight="70" backgroundColor="#1b2028" foregroundColor="#ffffff" font="Regular;36" selectionPixmap="skin_default/sel.png" />

    <widget name="key_red" position="80,1300" size="200,60" font="Regular;36" halign="center" valign="center" foregroundColor="#ffffff" backgroundColor="#c94343" />
    <widget name="key_green" position="300,1300" size="260,60" font="Regular;36" halign="center" valign="center" foregroundColor="#101216" backgroundColor="#6ed47f" />
</screen>