<screen name="SCSearchMain" position="center,center" size="2560,1440" title="SC Search - Streaming Community">
    <ePixmap position="0,0" size="2560,1440" pixmap="skin_default/background.png" zPosition="-1" />
    <widget name="background" position="0,0" size="2560,1440" backgroundColor="#0d1117" zPosition="0" />
    <widget name="divider" position="1280,80" size="2,1280" zPosition="1" backgroundColor="#30363d" />

    <!-- Left Panel: Search & Results -->
    <widget name="search_term" position="80,80" size="1160,60" font="Regular;48" halign="left" valign="center" foregroundColor="#ffffff" backgroundColor="#0d1117" transparent="1" />
    <widget name="results_list" position="80,180" size="1160,1100" itemHeight="80" font="Regular;40" scrollbarMode="showOnDemand" backgroundColor="#161b22" foregroundColor="#f0f6fc" selectionPixmap="skin_default/sel.png" transparent="0" />

    <!-- Right Panel: Details -->
    <widget name="cover_pixmap" position="1340,180" size="400,600" zPosition="3" alphatest="on" />
    <widget name="details_title" position="1780,180" size="700,180" font="Regular;52" halign="left" valign="top" foregroundColor="#ffffff" backgroundColor="#0d1117" transparent="1" />
    <widget name="details_year" position="1780,370" size="700,60" font="Regular;40" halign="left" valign="center" foregroundColor="#8b949e" backgroundColor="#0d1117" transparent="1" />
    <widget name="details_description" position="1340,820" size="1140,460" font="Regular;36" foregroundColor="#f0f6fc" backgroundColor="#0d1117" transparent="1" />

    <!-- Control Bar -->
    <widget name="key_red" position="80,1370" size="300,60" font="Regular;36" halign="center" valign="center" foregroundColor="#ffffff" backgroundColor="#f85149" zPosition="2" />
    <widget name="key_green" position="400,1370" size="300,60" font="Regular;36" halign="center" valign="center" foregroundColor="#ffffff" backgroundColor="#30d158" zPosition="2" />
    <widget name="key_yellow" position="720,1370" size="300,60" font="Regular;36" halign="center" valign="center" foregroundColor="#ffffff" backgroundColor="#fbb03b" zPosition="2" />
    <widget name="key_blue" position="1040,1370" size="300,60" font="Regular;36" halign="center" valign="center" foregroundColor="#ffffff" backgroundColor="#1f6feb" zPosition="2" />
</screen>