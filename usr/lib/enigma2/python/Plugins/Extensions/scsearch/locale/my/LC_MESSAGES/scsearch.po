msgid "TV Series\nSeasons: %d\nTotal episodes: %d\nPress GREEN to play"
msgstr "TV Series\nဇာတ်လမ်းတွဲများ- %d\nစုစုပေါင်းအပိုင်းများ- %d\nကစားရန် GREEN ကိုနှိပ်ပါ"

msgid "Type: %s"
msgstr "အမျိုးအစား- %s"

msgid "Unable to get stream for this episode"
msgstr "ဤဇာတ်လမ်းတွဲအတွက် တိုက်ရိုက်ထုတ်လွှင့်မှုကို ရယူ၍မရပါ။"

msgid "Unable to get stream URL for download"
msgstr "ဒေါင်းလုဒ်အတွက် တိုက်ရိုက်လွှင့် URL ကို ရယူ၍မရပါ။"

msgid "Unable to get streaming URL"
msgstr "တိုက်ရိုက်လွှင့် URL ကို မရပါ။"

msgid "Unable to load content details"
msgstr "အကြောင်းအရာအသေးစိတ်များကို တင်၍မရပါ။"

msgid "Unable to open details for this content"
msgstr "ဤအကြောင်းအရာအတွက် အသေးစိတ်အချက်အလက်များကို ဖွင့်၍မရပါ။"

msgid "Unable to resolve the video stream"
msgstr "ဗီဒီယိုစီးကြောင်းကို ဖြေရှင်း၍မရပါ။"

msgid "Unable to retrieve information from TMDB."
msgstr "TMDB မှ အချက်အလက်များကို ရယူ၍မရပါ။"

msgid "Unknown"
msgstr "မသိ"

msgid "UP/DOWN groups  |  LEFT/RIGHT cards  |  OK open  |  YELLOW = Downloads"
msgstr "UP/DOWN အဖွဲ့များ | ဘယ်/ညာ ကတ်များ | အိုကေဖွင့် | YELLOW = ဒေါင်းလုဒ်များ"

msgid "Updated, %d groups unavailable"
msgstr "အပ်ဒိတ်လုပ်ထားသည်၊ %d အဖွဲ့များ မရရှိနိုင်ပါ။"

msgid "Updating"
msgstr "အဆင့်မြှင့်တင်ခြင်း။"

msgid "Updating cards %d/%d"
msgstr "ကတ်များ %d/%d ကို အပ်ဒိတ်လုပ်နေသည်။"

msgid "Use the numeric keys on the remote\nto enter the captcha code\nGREEN = Confirm, RED = Cancel"
msgstr "captcha code\nGREEN = အတည်ပြုရန်၊ RED = ပယ်ဖျက်ရန် အဝေးထိန်း\nရှိ ဂဏန်းသော့များကို အသုံးပြုပါ။"

msgid "Waiting"
msgstr "စောင့်နေသည်။"

